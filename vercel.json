{
  "cleanUrls": true,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "checkout/**/*.html", "use": "@vercel/static" },
    { "src": "report/**/*.html", "use": "@vercel/static" },
    { "src": "report/**/*.js", "use": "@vercel/static" },
    { "src": "track/**/*.html", "use": "@vercel/static" },
    { "src": "address/**/*.html", "use": "@vercel/static" },
    { "src": "admin/**/*.html", "use": "@vercel/static" },
    { "src": "admin/**/*.js", "use": "@vercel/static" },
    { "src": "Assets/**/*", "use": "@vercel/static" },
    { "src": "docs/**/*", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/storefront/daddygrab-catalog", "dest": "/api/storefront/daddygrab-catalog.js" },
    { "src": "/api/storefront/daddygrab-checkout", "dest": "/api/storefront/daddygrab-checkout.js" },
    { "src": "/api/storefront/daddygrab-support", "dest": "/api/storefront/daddygrab-support.js" },
    { "src": "/api/storefront/daddygrab-track", "dest": "/api/storefront/daddygrab-track.js" },
    { "src": "/api/admin/daddygrab-admin", "dest": "/api/admin/daddygrab-admin.js" },
    { "handle": "filesystem" },
    { "src": "/checkout", "dest": "/checkout/index.html" },
    { "src": "/report", "dest": "/report/index.html" },
    { "src": "/track", "dest": "/track/index.html" },
    { "src": "/address", "dest": "/address/index.html" },
    { "src": "/admin", "dest": "/admin/index.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
